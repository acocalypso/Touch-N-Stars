{
  "name": "touch-n-stars",
  "version": "5.0.0-beta12",
  "private": true,
  "type": "module",
  "scripts": {
    "serve": "npm run lint:eslint && node scripts/generate-plugin-registry.js && node scripts/generate-whats-new.js && vite",
    "build": "npm run lint:eslint && npm run build:app",
    "build:app": "node scripts/generate-plugin-registry.js && node scripts/generate-whats-new.js && vite build",
    "build:native": "npm run lint && cross-env EXCLUDE_STELLARIUM_DATA=true npm run build:app",
    "preview": "vite preview",
    "preview:smoke": "start-server-and-test \"vite preview --host 127.0.0.1 --port 4173\" http://127.0.0.1:4173 \"node -e \\\"fetch('http://127.0.0.1:4173').then((r)=>{if(!r.ok)process.exit(1);})\\\"\"",
    "ci:install": "npm ci",
    "lint": "eslint . --ext .js,.vue",
    "lint:eslint": "eslint . --ext .js,.vue --fix",
    "lint:fix": "eslint . --ext .js,.vue --fix",
    "typecheck": "vue-tsc --noEmit -p jsconfig.json",
    "testbuild": "node scripts/generate-plugin-registry.js && node scripts/generate-whats-new.js && npm run lint:eslint && cross-env VITE_OUT_DIR=\"%LOCALAPPDATA%\\NINA\\Plugins\\3.0.0\\Touch 'N' Stars\\app\" vite build",
    "format": "prettier --write \"src/**/*.{js,vue,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,vue,json,css,md}\"",
    "test:run": "node --test \"src/**/__tests__/*.test.js\"",
    "test:coverage": "c8 --reporter=text --reporter=lcov node --test \"src/**/__tests__/*.test.js\"",
    "ionic:build": "npm run lint:eslint  && node scripts/generate-whats-new.js && npm run build:native",
    "ionic:serve": "npm run serve",
    "locale:entry": "node scripts/add-locale-entry.js",
    "locale:entry:all": "node scripts/add-locale-entry-all.js",
    "locale:find-missing-keys": "node scripts/find-missing-keys.js",
    "i18n:check": "node scripts/check-i18n.mjs",
    "generate-plugins": "node scripts/generate-plugin-registry.js",
    "generate-whats-new": "node scripts/generate-whats-new.js",
    "create-plugin": "node scripts/generate-plugin.js",
    "ci:verify": "npm run lint && npm run typecheck && npm run test:coverage && npm run format:check && npm run i18n:check && npm run build",
    "prepare": "husky"
  },
  "dependencies": {
    "@acocalypso/celestia-atlas": "git+https://github.com/acocalypso/celestia_atlas.git#33901928bbbee2193c76cab0f61b30bf38cbe4fc",
    "@acovanconis/capacitor-mdns": "0.0.4",
    "@capacitor-community/keep-awake": "8.0.1",
    "@capacitor-community/media": "9.1.0",
    "@capacitor/android": "8.4.1",
    "@capacitor/app": "8.1.0",
    "@capacitor/core": "8.4.1",
    "@capacitor/filesystem": "8.1.2",
    "@capacitor/geolocation": "8.2.0",
    "@capacitor/haptics": "8.0.2",
    "@capacitor/ios": "8.4.1",
    "@capacitor/keyboard": "8.0.5",
    "@capacitor/status-bar": "8.0.2",
    "@capawesome/capacitor-android-edge-to-edge-support": "8.0.8",
    "@capawesome/capacitor-file-picker": "8.0.3",
    "@capgo/capacitor-updater": "8.50.2",
    "@heroicons/vue": "^2.2.0",
    "@microsoft/signalr": "^10.0.0",
    "@novnc/novnc": "1.5.0",
    "@panzoom/panzoom": "4.6.2",
    "@pinkcao/vue-drag-resize-rotate": "^2.0.0",
    "@unhead/vue": "3.1.6",
    "@vueuse/core": "14.3.0",
    "axios": "1.18.1",
    "capacitor-getlocalip": "0.0.3",
    "chart.js": "4.5.1",
    "date-fns": "4.4.0",
    "file-saver": "^2.0.5",
    "i18n": "0.15.3",
    "jszip": "^3.10.1",
    "papaparse": "5.5.4",
    "pinia": "3.0.4",
    "pinia-plugin-persistedstate": "4.7.1",
    "uuid": "14.0.1",
    "vue": "3.5.39",
    "vue-draggable-next": "^2.2.1",
    "vue-i18n": "11.4.6",
    "vue-router": "5.1.0",
    "vue-scroll-picker": "^2.0.1",
    "vue3-moveable": "^0.28.0",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@capacitor/cli": "8.4.1",
    "@tailwindcss/vite": "4.3.2",
    "@vitejs/plugin-vue": "6.0.7",
    "c8": "11.0.0",
    "cross-env": "10.1.0",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-vue": "10.9.2",
    "husky": "^9.1.7",
    "lint-staged": "17.0.8",
    "lodash": "4.18.1",
    "prettier": "3.9.4",
    "start-server-and-test": "3.0.11",
    "tailwindcss": "^4.3.1",
    "typescript": "6.0.3",
    "vite": "8.1.3",
    "vue-eslint-parser": "10.4.1",
    "vue-tsc": "3.3.6"
  },
  "lint-staged": {
    "src/**/*.{js,vue}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "overrides": {
    "serialize-javascript": "^7.0.5"
  }
}
